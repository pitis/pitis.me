---
import Layout from '../../layouts/Layout.astro'
import { getWorkBySlug, workItems } from '../../data/work'
import { MoveRight, ExternalLink } from '@lucide/astro'

export function getStaticPaths() {
  return workItems.map((item) => ({
    params: { slug: item.slug },
    props: { project: item },
  }))
}

const { project } = Astro.props
const siteUrl = 'https://pitis.me'
const bodyCopy =
  'longDescription' in project && project.longDescription
    ? project.longDescription
    : project.description
---

<Layout
  title={`${project.company} | Radu Pitis`}
  description={project.description}
  canonical={`${siteUrl}/work/${project.slug}`}
  keywords={'keywords' in project ? project.keywords : undefined}
>
  <main class='max-w-4xl mx-auto px-6 sm:px-8 lg:px-16 py-20'>
    <a
      href='/'
      class='inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground mb-12 transition-colors'
    >
      ← Back
    </a>
    <article class='space-y-10'>
      <header class='space-y-4'>
        <div class='text-muted-foreground font-mono text-sm'>{project.year}</div>
        <h1 class='text-3xl sm:text-4xl font-light'>{project.company}</h1>
        {'tagline' in project && project.tagline && (
          <p class='text-xl text-muted-foreground'>{project.tagline}</p>
        )}
        <p class='text-muted-foreground'>{project.role}</p>
      </header>

      <div class='space-y-6 max-w-2xl'>
        <p class='text-muted-foreground leading-relaxed'>
          {bodyCopy}
        </p>

        {'highlights' in project && project.highlights && project.highlights.length > 0 && (
          <ul class='space-y-2'>
            {project.highlights.map((item) => (
              <li class='flex items-start gap-2 text-muted-foreground'>
                <span class='text-foreground/60 mt-0.5'>·</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        )}
      </div>

      <div class='flex flex-wrap gap-2'>
        {project.tech.map((tech) => (
          <span class='px-2 py-1 text-xs text-muted-foreground rounded border border-border'>
            {tech}
          </span>
        ))}
      </div>

      <a
        href={project.url}
        target='_blank'
        rel='noopener noreferrer'
        class='inline-flex items-center gap-2 text-sm font-medium hover:underline group'
      >
        <span>Visit {project.company}</span>
        <ExternalLink class='w-4 h-4 transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform' />
      </a>
    </article>
  </main>
</Layout>
